{
  "name": "datamind",
  "version": "1.1.0",
  "description": "智能数据分析助手 — 上传数据，用自然语言分析，无需 SQL/Python。支持 CSV/Excel 导入、自然语言查询、自动洞察分析和报告生成。",
  "main": "dist/cli/index.js",
  "bin": {
    "datamind": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-public",
    "copy-public": "mkdir -p dist/ui/public && cp src/ui/public/index.html dist/ui/public/",
    "start": "ts-node src/cli/index.ts",
    "dev": "ts-node src/cli/index.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wenbingYu/datamind.git"
  },
  "keywords": [
    "data-analysis",
    "natural-language",
    "sql",
    "duckdb",
    "cli",
    "ai",
    "llm",
    "rag",
    "visualization",
    "business-intelligence",
    "nl2sql",
    "data-science"
  ],
  "author": "wenbingYu",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/wenbingYu/datamind/issues"
  },
  "homepage": "https://github.com/wenbingYu/datamind#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "duckdb-async": "^1.4.2",
    "echarts": "^6.0.0",
    "express": "^5.2.1",
    "marked": "^17.0.5",
    "multer": "^2.1.1",
    "openai": "^6.32.0",
    "ora": "^9.3.0",
    "xlsx": "^0.18.5"
  }
}
